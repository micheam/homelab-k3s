# Minecraft Fabric Server Configuration
EULA=TRUE
VERSION=1.21.11
TYPE=FABRIC
MEMORY=4G
DIFFICULTY=normal
GAMEMODE=survival
MAX_PLAYERS=10
VIEW_DISTANCE=10

# Modrinth mod downloads
MODRINTH_PROJECTS=fabric-api,sodium,lithium,iris
MODRINTH_DOWNLOAD_DEPENDENCIES=required

# Performance optimizations
USE_AIKAR_FLAGS=true

# Players
OPS=micheam
WHITELIST=micheam,naotomae

# Server properties
MOTD=Minecraft Fabric Server with Performance Mods
ENABLE_COMMAND_BLOCK=true
SPAWN_PROTECTION=16
